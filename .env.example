# IBKR Connection (no API key needed - connects via socket to running TWS/Gateway)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# LLM provider — "gemini" (primary; auto-falls back to Ollama on error/exhaustion)
# or "ollama" (legacy local-only path). On any Gemini error, rate limit, credit
# exhaustion, or missing key the bot transparently uses Ollama until process restart.
AI_PROVIDER=gemini

# Gemini (primary). Two ways to configure keys:
#   GEMINI_API_KEYS=key1,key2,key3   ← preferred: comma-separated rotation list.
#                                      The bot round-robins through every call,
#                                      tripling free-tier RPD headroom (1k → 3k/day).
#                                      Use 1, 2, or 3 keys — rotation auto-scales.
#   GEMINI_API_KEY=key1              ← legacy: single key, used only when
#                                      GEMINI_API_KEYS is unset/empty.
# Leave both blank to skip Gemini and use Ollama only.
# Get keys at https://aistudio.google.com/apikey (free tier: 15 RPM / 1,000 RPD per key).
GEMINI_API_KEYS=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_HOST=https://generativelanguage.googleapis.com

# Ollama (fallback) — runs locally, no API key. Install Ollama and `ollama pull qwen2.5:7b`.
AI_MODEL=qwen2.5:7b
OLLAMA_HOST=http://localhost:11434

# Telegram Notifications
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=123456789

# News API
TAVILY_API_KEY=tvly-...
