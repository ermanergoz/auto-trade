# IBKR Connection (no API key needed - connects via socket to running TWS/Gateway)
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# LLM provider — "gemini" (primary; auto-falls back to Ollama on error/exhaustion)
# or "ollama" (legacy local-only path). On any Gemini error, rate limit, credit
# exhaustion, or missing key the bot transparently uses Ollama until process restart.
AI_PROVIDER=gemini

# Gemini (primary). Leave GEMINI_API_KEY blank to skip Gemini and use Ollama only.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_HOST=https://generativelanguage.googleapis.com

# Ollama (fallback) — runs locally, no API key. Install Ollama and `ollama pull qwen2.5:7b`.
AI_MODEL=qwen2.5:7b
OLLAMA_HOST=http://localhost:11434

# Telegram Notifications
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_CHAT_ID=123456789

# News API
TAVILY_API_KEY=tvly-...
